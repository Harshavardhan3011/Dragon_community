generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactEnquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  type      String
  subject   String
  message   String
  status    String   @default("NEW")
  reference String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id           String   @id @default(cuid())
  name         String
  role         String
  bio          String
  image        String?
  favoriteGame String?
  socialLink   String?
  skills       String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  category    String
  authorName  String?
  status      String    @default("DRAFT")
  isFeatured  Boolean   @default(false)
  isPinned    Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model GuildMember {
  id                String   @id @default(cuid())
  name              String
  nickname          String
  avatar            String?
  uid               String   @unique
  role              String   @default("PLAYER") // GUILD_LEADER, ACTING_GUILD_LEADER, OFFICER, PLAYER
  status            String   @default("ACTIVE") // ACTIVE, OFFLINE, ON_BREAK
  joinedAt          DateTime @default(now())
  favoriteGame      String?
  displayOrder      Int      @default(0)
  isActive          Boolean  @default(true)
  
  // Profile stats and info
  country           String?
  about             String?
  achievements      String?
  rank              String?
  level             Int?
  matchesPlayed     Int?
  wins              Int?
  mvpCount          Int?
  favoriteWeapon    String?
  favoriteCharacter String?
  favoritePet       String?
  device            String?
  
  // Social Links
  youtube           String?
  instagram         String?
  discord           String?
  facebook          String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


